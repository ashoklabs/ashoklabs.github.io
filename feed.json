---
layout: null
permalink: /feed.json
sitemap: false
---
{
  "version": "https://jsonfeed.org/version/1.1",
  "title": {{ site.title | jsonify }},
  "home_page_url": {{ site.url | jsonify }},
  "feed_url": {{ site.url | append: "/feed.json" | jsonify }},
  "description": {{ site.description | jsonify }},
  "authors": [
    {
      "name": {{ site.author.name | jsonify }},
      "url": {{ site.author.url | jsonify }}
    }
  ],
  "items": [
    {% for post in site.posts %}
    {
      "id": {{ site.url | append: post.url | jsonify }},
      "url": {{ site.url | append: post.url | jsonify }},
      "title": {{ post.title | jsonify }},
      "summary": {{ post.description | default: "" | jsonify }},
      "content_text": {{ post.content | strip_html | strip_newlines | jsonify }},
      "date_published": {{ post.date | date_to_xmlschema | jsonify }},
      "tags": {{ post.categories | jsonify }},
      "image": {{ post.image | default: "" | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
