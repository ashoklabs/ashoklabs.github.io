---
layout: null
sitemap: false
---
[{% for post in site.posts %}{"id":{{ forloop.index }},"title":{{ post.title | jsonify }},"url":{{ post.url | relative_url | jsonify }},"description":{{ post.description | default: "" | jsonify }},"categories":{{ post.categories | join: ", " | jsonify }},"date":{{ post.date | date: "%B %d, %Y" | jsonify }},"content":{{ post.content | strip_html | strip_newlines | truncatewords: 200 | jsonify }}}{% unless forloop.last %},{% endunless %}{% endfor %}]
